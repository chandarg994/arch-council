# ARCH-COUNCIL Environment Configuration
# Copy this file to .env and fill in your values

# OpenRouter API key — get one at https://openrouter.ai
# Single key gives access to GPT-4o, Claude, Gemini, Grok simultaneously
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: override individual model assignments
# COUNCIL_CHAIRMAN_MODEL=anthropic/claude-opus-4-5
# COUNCIL_BUSINESS_MODEL=anthropic/claude-sonnet-4-5
# COUNCIL_DATA_MODEL=openai/gpt-4o
# COUNCIL_APP_MODEL=google/gemini-2.0-flash-001
# COUNCIL_TECH_MODEL=x-ai/grok-3
# COUNCIL_AI_MODEL=openai/gpt-4o
# COUNCIL_RISK_MODEL=google/gemini-2.0-flash-001

# Ratchet loop settings
RATCHET_MAX_ITERATIONS=20
